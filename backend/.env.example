# =============================================================================
# SEGMENT 1 — CONTROL FLAG
# Set PRODUCTION=1 to use Supabase + R2 + Cloud Run (production).
# Set PRODUCTION=0 to use local Postgres + local file storage (development).
# =============================================================================
PRODUCTION=0


# =============================================================================
# SEGMENT 2 — UNIVERSAL / COMMON (used in BOTH dev and prod)
# =============================================================================

# JWT
JWT_SECRET_KEY=ncrpgu345rugbvjrvb2r4gbu-rvy29r42g5hr-fp4yguwq4fbp3iubgy-49jefbfojrg-xyz789

# OTP HMAC signing secret
OTP_HMAC_SECRET=otp-hmac-secret-hfbvqihrv-rqeg4rv-reqf34fveqb-h45bwteqg5

# Resend (email OTP) — shared across dev & prod
RESEND_API_KEY=re_ejy4ppic_JnZasW7QpGh5Vs5etRZnoHRN
# Sender email — must use a verified domain on Resend (https://resend.com/domains)
# Free tier default: onboarding@resend.dev (only sends to your Resend account email)
# After verifying your domain, use: Aura Prints <noreply@yourdomain.com>
RESEND_FROM_EMAIL=Aura Prints <onboarding@resend.dev>

# Cron job authentication secret
CRON_SECRET_KEY=aura-prints-default-cron-secret-key-change-in-production


# =============================================================================
# SEGMENT 3 — DEVELOPMENT (active when PRODUCTION=0)
# Local Postgres + local disk uploads
# =============================================================================

# Local PostgreSQL (docker or native)
DEV_DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/aura_prints

# Local file storage base URL served by FastAPI /uploads static mount
DEV_STORAGE_BASE_URL=http://localhost:8000/uploads

# Dev backend URL
DEV_BACKEND_URL=http://localhost:8000


# =============================================================================
# SEGMENT 4 — PRODUCTION (active when PRODUCTION=1)
# Supabase (Transaction Pooler) + Cloudflare R2 + Cloud Run
# =============================================================================

# Supabase — Transaction Pooler (PgBouncer, port 6543)
# Format: postgresql+asyncpg://<user>:<password>@<pooler-host>:6543/postgres
PROD_DATABASE_URL=postgresql+asyncpg://postgres.hwqylmxwtrrsgdijnuek:AuraPrintsDb_2026_Secure@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Cloudflare R2 Object Storage
PROD_R2_ACCOUNT_ID=dbb6ca92e906b52b094004208f872a0a
